// prisma/schema.prisma

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

model User {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  username    String   @unique
  email       String   @unique
  password    String
  role        Role     @default(USER)
  
  // Extra Profile Info
  fullName    String
  address     String?
  phoneNumber String?
  
  createdAt   DateTime @default(now())

  // ADD THIS LINE: Prisma requires the reverse relationship
  tanks       Tank[]
}

model Tank {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  tankId       String    @unique // e.g., "GUARD-001"
  name         String
  
  // Ownership
  userId       String    @db.ObjectId
  user         User      @relation(fields: [userId], references: [id])

  // Safe Ranges (Admin Controlled)
  tempMin      Float     @default(24.0)
  tempMax      Float     @default(28.0)
  phMin        Float     @default(6.5)
  phMax        Float     @default(8.5)
  tdsMin       Float     @default(200.0)
  tdsMax       Float     @default(600.0)
  turbidityMax Float     @default(20.0)
  
  // Latest State
  lastTemp     Float?
  lastPh       Float?
  lastTds      Float?
  lastTurb     Float?
  lastWaterLevel Float?  // <-- ADD THIS LINE
  status       String    @default("offline")
  
  // Relations & Metadata
  updatedAt    DateTime  @updatedAt
  createdAt    DateTime  @default(now())
}
