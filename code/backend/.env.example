# ─── Server ──────────────────────────────────────────────────────────────────
PORT=5000

# ─── MongoDB (Prisma) ────────────────────────────────────────────────────────
DATABASE_URL=mongodb://localhost:27017/iot_db

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-strong-secret-here
JWT_EXPIRY=1d

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id

# ─── MQTT Broker (HiveMQ Cloud) ─────────────────────────────────────────────
MQTT_BROKER_URL=mqtts://your-cluster.s1.eu.hivemq.cloud:8883
MQTT_USERNAME=your-mqtt-username
MQTT_PASSWORD=your-mqtt-password

# ─── InfluxDB ────────────────────────────────────────────────────────────────
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=your-influx-admin-token
INFLUX_ORG=G.U.A.R.D
INFLUX_BUCKET=guard_sensors

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Frontend URL (for verification email links) ────────────────────────────
# Comment out to auto-detect LAN IP for mobile testing
FRONTEND_URL=http://localhost:5173

# ─── Email (SMTP) ───────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# ─── Super Admin (Initial Setup) ─────────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_USERNAME=super_admin
SUPER_ADMIN_PASSWORD=your_secure_password
SUPER_ADMIN_FULLNAME=System Super Admin

# ─── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# ─── Device API Key (ESP32 / IoT Hardware Authentication) ─────────────────────
# Shared secret between the backend and ESP32 firmware.
# The ESP32 must include this in the X-Device-Key HTTP header when posting sensor data.
# Generate with: openssl rand -hex 32
DEVICE_API_KEY=your_device_api_key_here
