# ===== REQUIRED ENVIRONMENT VARIABLES =====
# The backend WILL NOT START without these. Fill in all values before running.

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# Example: postgresql://guard:guardpass@localhost:5432/guarddb
DATABASE_URL=postgresql://guard:guardpass@localhost:5432/guarddb

# JWT secret for signing authentication tokens
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Min 32 characters
JWT_SECRET=your-64-char-jwt-secret-here-replace-with-output-of-crypto-command

# ===== OPTIONAL ENVIRONMENT VARIABLES =====
# Most have defaults, but can be overridden here.

# Backend server port (default: 3000)
PORT=3000

# Node environment (default: development)
NODE_ENV=development

# Google OAuth Client ID (leave blank to disable Google OAuth)
# Get from: https://console.cloud.google.com
# Format: 123456789-abc.apps.googleusercontent.com
GOOGLE_CLIENT_ID=

# MQTT broker connection URL (default: mqtt://mosquitto:1883 for Docker, mqtt://localhost:1883 for local)
MQTT_BROKER_URL=mqtt://localhost:1883

# Optional MQTT auth credentials (leave blank if broker has no auth)
MQTT_USERNAME=
MQTT_PASSWORD=

# CORS allowed origins (comma-separated, default: http://localhost:5173)
# Used for React frontend during development
CORS_ORIGIN=http://localhost:5173

# JWT token expiry time (default: 1d)
JWT_EXPIRY=1d

# ===== ALERT THRESHOLDS =====
# All values are configurable thresholds for the alert engine.
# Units and defaults are shown below.

# Temperature thresholds (°C)
TEMP_MAX=32
TEMP_MIN=20

# pH thresholds
PH_MAX=8.5
PH_MIN=6.5

# Turbidity threshold (NTU)
TURBIDITY_MAX=50

# Water level threshold (%)
WATER_LEVEL_MIN=20

# ===== EMAIL ALERTS (OPTIONAL) =====
# Leave all blank to disable email notifications.
# When enabled, alerts will be sent to ALERT_EMAIL via SMTP.

# SMTP server hostname
SMTP_HOST=smtp.gmail.com

# SMTP port (typically 587 for TLS, 465 for SSL)
SMTP_PORT=587

# SMTP username (usually same as email address)
SMTP_USER=your-email@gmail.com

# SMTP password or app-specific password
# For Gmail: generate at https://myaccount.google.com/apppasswords
SMTP_PASS=your-app-password-here

# Email address to receive alerts
ALERT_EMAIL=recipient@fish-shop.com
