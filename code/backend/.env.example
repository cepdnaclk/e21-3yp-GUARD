# ─────────────────────────────────────────
# G.U.A.R.D Backend — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# Application
PORT=3000
NODE_ENV=development

# ─── Database ───────────────────────────
# For local dev: change host to 'localhost'
# For Docker:    host stays 'postgres'
DATABASE_URL="postgresql://guard:guardpass@postgres:5432/guarddb"

# ─── JWT ────────────────────────────────
# Generate a strong random string (e.g. openssl rand -hex 64)
JWT_SECRET=replace_this_with_a_strong_random_secret
JWT_EXPIRY=1d

# ─── Google OAuth ────────────────────────
# See README.md for step-by-step setup instructions
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── MQTT Broker ─────────────────────────
# For Docker:    mqtt://mosquitto:1883
# For local dev: mqtt://localhost:1883
MQTT_BROKER_URL=mqtt://mosquitto:1883

# ─── CORS ───────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# ─── Alert Thresholds ────────────────────
# All thresholds are configurable here
TEMP_MAX=32
TEMP_MIN=20
PH_MAX=8.5
PH_MIN=6.5
TURBIDITY_MAX=50
WATER_LEVEL_MIN=20

# ─── Email Notifications (optional) ──────
# Leave all SMTP fields blank to disable email alerts
# Supports any SMTP provider (Gmail, SendGrid, Mailgun, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=
